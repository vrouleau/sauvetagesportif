# Meet Manager App — Environment Variables
# Copy to .env and fill in your values

# Admin PIN (used to log in as admin)
ADMIN_PIN=314159

# Resend (email delivery)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# Public URL of the frontend (used in email links)
APP_BASE_URL=http://localhost:8001

# Secret key for encrypting PINs in one-time links
SECRET_KEY=change-me-to-a-random-string

# Stripe (draft invoice creation) — secret key (sk_test_... or sk_live_...)
STRIPE_API_KEY=

# Path to the meet template .smb file served to organizers as a starting point.
# The .smb is the primary template: it preserves SPLASH combined-event definitions (which
# .lxf exports omit) and is used to restore the full meet structure each season.
# Defaults to templates/meet.smb from the repo (mounted read-only into the container).
MEET_TEMPLATE=/app/templates/meet.smb

# Best time expiry window in months (default: 18). Times older than this are
# purged from the DB when an athlete's registration page is loaded.
BEST_TIME_MAX_AGE_MONTHS=18

# Support email shown in footer and invite emails (optional)
SUPPORT_EMAIL=

# Cloudflare Turnstile CAPTCHA (self-invite page)
# Get keys from https://dash.cloudflare.com/ → Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
{
  "name": "@meetmgr/meet-app",
  "version": "0.3.35",
  "private": true,
  "author": "Société de sauvetage",
  "description": "Electron desktop app for running lifesaving competitions",
  "repository": "github:vrouleau/sauvetagesportif",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win",
    "clean": "node scripts/clean-build.js",
    "test": "npm rebuild better-sqlite3 && vitest run",
    "test:watch": "npm rebuild better-sqlite3 && vitest",
    "rebuild": "node scripts/rebuild.js",
    "postinstall": "node scripts/rebuild.js"
  },
  "build": {
    "appId": "com.sauvetagemeet",
    "productName": "SauvetageMeet",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "../../config/combined-events-config.json",
        "to": "combined-events-config.json"
      },
      {
        "from": "../../config/dsq-codes.json",
        "to": "dsq-codes.json"
      },
      {
        "from": "../../config/template_pool.lxf",
        "to": "template_pool.lxf"
      },
      {
        "from": "../../config/template_beach.lxf",
        "to": "template_beach.lxf"
      },
      {
        "from": "../../config/point-scores-config.json",
        "to": "point-scores-config.json"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.sports",
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "Pour scanner les fiches chrono avec la caméra."
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@ericblade/quagga2": "^1.12.1",
    "better-sqlite3": "^12.11.1",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.19",
    "electron": "42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "fast-check": "^4.8.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^6.0.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  }
}
